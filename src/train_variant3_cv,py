import os, json, csv, argparse, random
from pathlib import Path

import numpy as np
import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader
from torchvision import transforms
from PIL import Image

from sklearn.model_selection import StratifiedKFold
from sklearn.metrics import precision_recall_fscore_support, confusion_matrix, accuracy_score

# your model
from models.dino_multiscale_coag_classifier import DinoMultiScaleClassifier


IMG_EXTS = {".jpg", ".jpeg", ".png", ".bmp", ".tif", ".tiff", ".webp"}


def set_seed(seed: int):
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)


def list_all_images_under_split(root: Path, split: str):
    # expects: root/{split}/{class}/{img}
    split_dir = root / split
    if not split_dir.exists():
        return [], []
    classes = sorted([p.name for p in split_dir.iterdir() if p.is_dir()])
    cls_to_idx = {c:i for i,c in enumerate(classes)}

    paths, labels = [], []
    for c in classes:
        for p in (split_dir / c).rglob("*"):
            if p.suffix.lower() in IMG_EXTS:
                paths.append(p)
                labels.append(cls_to_idx[c])
    return paths, labels


def load_classes(data_root: Path) -> list[str]:
    # from train folder names (your classes.txt exists but we keep robust)
    train_dir = data_root / "train"
    classes = sorted([p.name for p in train_dir.iterdir() if p.is_dir()])
    return classes


class ImagePathDataset(Dataset):
    def __init__(self, paths, labels, transform):
        self.paths = list(paths)
        self.labels = np.array(labels, dtype=np.int64)
        self.tfm = transform

    def __len__(self):
        return len(self.paths)

    def __getitem__(self, i):
        p = self.paths[i]
        y = int(self.labels[i])
        img = Image.open(p).convert("RGB")
        if self.tfm is not None:
            img = self.tfm(img)
        return img, y


@torch.no_grad()
def evaluate(model, loader, device):
    model.eval()
    ys, ps = [], []
    for x, y in loader:
        x = x.to(device, non_blocking=True)
        logits = model(x)
        pred = logits.argmax(1).cpu().numpy()
        ys.append(y.numpy())
        ps.append(pred)
    y = np.concatenate(ys)
    p = np.concatenate(ps)

    acc = float(accuracy_score(y, p))
    prec, rec, f1, _ = precision_recall_fscore_support(y, p, average="macro", zero_division=0)
    prec_w, rec_w, f1_w, _ = precision_recall_fscore_support(y, p, average="weighted", zero_division=0)

    return {
        "acc": acc,
        "precision_macro": float(prec),
        "recall_macro": float(rec),
        "f1_macro": float(f1),
        "precision_weighted": float(prec_w),
        "recall_weighted": float(rec_w),
        "f1_weighted": float(f1_w),
        "y_true": y,
        "y_pred": p,
    }


def train_one_epoch(model, loader, opt, device, scaler=None):
    model.train()
    ce = nn.CrossEntropyLoss()
    total_loss = 0.0
    for x, y in loader:
        x = x.to(device, non_blocking=True)
        y = y.to(device, non_blocking=True)

        opt.zero_grad(set_to_none=True)

        if scaler is None:
            logits = model(x)
            loss = ce(logits, y)
            loss.backward()
            opt.step()
        else:
            with torch.cuda.amp.autocast():
                logits = model(x)
                loss = ce(logits, y)
            scaler.scale(loss).backward()
            scaler.step(opt)
            scaler.update()

        total_loss += float(loss.item())

    return total_loss / max(len(loader), 1)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--dataset", required=True)
    ap.add_argument("--data_root", default="data")
    ap.add_argument("--kfold", type=int, default=5)
    ap.add_argument("--fold", type=int, required=True)
    ap.add_argument("--epochs", type=int, default=100)
    ap.add_argument("--bs", type=int, default=32)
    ap.add_argument("--img", type=int, default=224)
    ap.add_argument("--lr", type=float, default=3e-4)
    ap.add_argument("--wd", type=float, default=1e-2)
    ap.add_argument("--seed", type=int, default=42)
    ap.add_argument("--freeze_dinov3", action="store_true")
    ap.add_argument("--out", default="runs_variant3_cv5")
    args = ap.parse_args()

    set_seed(args.seed)

    ds_root = Path(args.data_root) / args.dataset
    assert ds_root.exists(), f"Dataset folder not found: {ds_root}"

    classes = load_classes(ds_root)
    ncls = len(classes)
    assert ncls >= 2, f"Need >=2 classes, found {ncls}"

    # Build FULL pool from train+val+test to do true 5-fold CV on ALL images
    # (this is what people usually mean by “5-fold cross-validation”)
    paths_tr, y_tr = list_all_images_under_split(ds_root, "train")
    paths_va, y_va = list_all_images_under_split(ds_root, "val")
    paths_te, y_te = list_all_images_under_split(ds_root, "test")
    paths = paths_tr + paths_va + paths_te
    labels = np.array(y_tr + y_va + y_te, dtype=np.int64)

    assert len(paths) == len(labels) and len(paths) > 0, "No images found for CV."

    # Transforms
    tfm_train = transforms.Compose([
        transforms.Resize((args.img, args.img)),
        transforms.RandomHorizontalFlip(),
        transforms.RandomVerticalFlip(p=0.1),
        transforms.ColorJitter(0.1, 0.1, 0.1, 0.05),
        transforms.ToTensor(),
    ])
    tfm_eval = transforms.Compose([
        transforms.Resize((args.img, args.img)),
        transforms.ToTensor(),
    ])

    # Stratified KFold
    skf = StratifiedKFold(n_splits=args.kfold, shuffle=True, random_state=args.seed)
    folds = list(skf.split(np.zeros(len(labels)), labels))
    assert 0 <= args.fold < args.kfold
    train_idx, val_idx = folds[args.fold]

    run_dir = Path(args.out) / args.dataset / f"fold{args.fold}"
    run_dir.mkdir(parents=True, exist_ok=True)

    # Save split for reproducibility
    split_json = {
        "dataset": args.dataset,
        "fold": args.fold,
        "kfold": args.kfold,
        "seed": args.seed,
        "num_images": len(paths),
        "train_count": int(len(train_idx)),
        "val_count": int(len(val_idx)),
        "classes": classes,
        "train_paths": [str(paths[i]) for i in train_idx[:50]],  # sample preview only
        "val_paths": [str(paths[i]) for i in val_idx[:50]],
    }
    (run_dir / "split_preview.json").write_text(json.dumps(split_json, indent=2), encoding="utf-8")
    (run_dir / "classes.txt").write_text("\n".join(classes), encoding="utf-8")

    train_ds = ImagePathDataset([paths[i] for i in train_idx], labels[train_idx], tfm_train)
    val_ds   = ImagePathDataset([paths[i] for i in val_idx],   labels[val_idx],   tfm_eval)

    train_loader = DataLoader(train_ds, batch_size=args.bs, shuffle=True,  num_workers=4, pin_memory=True)
    val_loader   = DataLoader(val_ds,   batch_size=args.bs, shuffle=False, num_workers=4, pin_memory=True)

    device = "cuda" if torch.cuda.is_available() else "cpu"

    model = DinoMultiScaleClassifier(
        num_classes=ncls,
        freeze_backbone=args.freeze_dinov3,
    ).to(device)

    opt = torch.optim.AdamW(model.parameters(), lr=args.lr, weight_decay=args.wd)
    scaler = torch.cuda.amp.GradScaler(enabled=torch.cuda.is_available())

    # CSV per-epoch (only what matters)
    csv_path = run_dir / "metrics.csv"
    with open(csv_path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow([
            "epoch",
            "train_loss",
            "val_acc",
            "val_precision_macro",
            "val_recall_macro",
            "val_f1_macro",
            "val_precision_weighted",
            "val_recall_weighted",
            "val_f1_weighted",
        ])

    best_f1 = -1.0
    best_ckpt = run_dir / "best.ckpt"

    for ep in range(1, args.epochs + 1):
        tr_loss = train_one_epoch(model, train_loader, opt, device, scaler=scaler)
        val_m = evaluate(model, val_loader, device)

        with open(csv_path, "a", newline="") as f:
            w = csv.writer(f)
            w.writerow([
                ep,
                f"{tr_loss:.6f}",
                f"{val_m['acc']:.6f}",
                f"{val_m['precision_macro']:.6f}",
                f"{val_m['recall_macro']:.6f}",
                f"{val_m['f1_macro']:.6f}",
                f"{val_m['precision_weighted']:.6f}",
                f"{val_m['recall_weighted']:.6f}",
                f"{val_m['f1_weighted']:.6f}",
            ])

        print(f"[{args.dataset} fold{args.fold}] epoch {ep:03d}/{args.epochs} "
              f"train_loss={tr_loss:.4f} val_f1_macro={val_m['f1_macro']:.4f}")

        # Choose BEST by macro-F1 (scientifically better for imbalance)
        if val_m["f1_macro"] > best_f1:
            best_f1 = val_m["f1_macro"]
            torch.save({
                "model": model.state_dict(),
                "epoch": ep,
                "best_f1_macro": best_f1,
                "args": vars(args),
                "classes": classes,
            }, best_ckpt)

    # -------- Final eval artifacts on VAL fold using BEST checkpoint --------
    ckpt = torch.load(best_ckpt, map_location=device)
    model.load_state_dict(ckpt["model"])
    model.eval()

    val_m = evaluate(model, val_loader, device)
    y_true = val_m.pop("y_true")
    y_pred = val_m.pop("y_pred")

    # Confusion matrix (raw + normalized)
    cm = confusion_matrix(y_true, y_pred, labels=np.arange(ncls))
    cm_norm = confusion_matrix(y_true, y_pred, labels=np.arange(ncls), normalize="true")

    out_eval = {
        "best_epoch": int(ckpt["epoch"]),
        "best_f1_macro": float(ckpt["best_f1_macro"]),
        "val_metrics": val_m,
    }
    (run_dir / "eval_summary.json").write_text(json.dumps(out_eval, indent=2), encoding="utf-8")
    np.save(run_dir / "confusion_matrix.npy", cm)
    np.save(run_dir / "confusion_matrix_norm.npy", cm_norm)

    # Grad-CAM + t-SNE will be generated by a separate script (clean separation)
    # (so training stays lightweight)
    os.system(
        f"python -m src.visualize_fold "
        f"--ckpt {best_ckpt} --dataset {args.dataset} --data_root {args.data_root} "
        f"--kfold {args.kfold} --fold {args.fold} --img {args.img} --bs {args.bs} --out {run_dir}"
    )

    print(f"[DONE] saved best: {best_ckpt} | eval: {run_dir/'eval_summary.json'}")


if __name__ == "__main__":
    main()
