%%{init: {
  'theme':'base',
  'themeVariables':{
    'fontFamily':'Times New Roman, serif',
    'fontSize':'14px',
    'primaryColor':'#ffffff',
    'primaryTextColor':'#111111',
    'lineColor':'#111111'
  }
}}%%
flowchart LR
  classDef node fill:#ffffff,stroke:#111111,stroke-width:1.5px,color:#111111;
  classDef op   fill:#ffffff,stroke:#111111,stroke-width:1.5px,color:#111111;
  classDef add  fill:#ffffff,stroke:#111111,stroke-width:1.5px,color:#111111;
  linkStyle default stroke:#111111,stroke-width:1.2px;

  X["<b>x</b>"]:::node
  DW["Depth-wise<br/>conv"]:::op
  PW1["Point-wise<br/>conv"]:::op
  U["Unfold"]:::op

  subgraph Bx["<i>B×</i>"]
    direction LR
    SSA["Separable<br/>self-attention"]:::op
    ADD1(("⊕")):::add
    FFN["Feed-forward<br/>network"]:::op
    ADD2(("⊕")):::add
  end
  style Bx fill:#ffffff,stroke:#111111,stroke-width:1.5px,stroke-dasharray:5 5;

  FOLD["Fold"]:::op
  PW2["Point-wise<br/>conv"]:::op
  Y["<b>y</b>"]:::node

  X --> DW --> PW1 --> U --> SSA --> ADD1 --> FFN --> ADD2 --> FOLD --> PW2 --> Y
  U -.-> ADD1
  SSA -.-> ADD2
